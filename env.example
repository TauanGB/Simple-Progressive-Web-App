DJANGO_SETTINGS_MODULE=foco_especializado.settings.dev
DEBUG=1
SECRET_KEY=dev-secret-key

ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://sistemaeg3-production.up.railway.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# DB CASO USANDO MYSQL, CASO CONTRARIO DEIXAR PADRAO POIS FUNCIONARA VIA SQLITE(preencha p/ MySQL em testes/prod; omita em dev p/ usar SQLite)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=
MYSQL_USER=
MYSQL_PASSWORD=
USE_PYMYSQL=1

DJANGO_LOG_LEVEL=INFO
