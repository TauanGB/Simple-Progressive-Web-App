# Ambiente
DJANGO_SETTINGS_MODULE=foco_especializado.settings.dev
DEBUG=1
SECRET_KEY=dev-secret-key

# Hosts/CORS/CSRF (listas separadas por vÃ­rgula)
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://foco-especializado-production.up.railway.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# DB (preencha para MySQL em testes/prod; omita em dev para usar SQLite)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=
MYSQL_USER=
MYSQL_PASSWORD=
USE_PYMYSQL=0

# Log
DJANGO_LOG_LEVEL=INFO

# PWA (opcional)
PWA_ENABLED=1
PWA_THEME_COLOR=#0f172a
PWA_BACKGROUND_COLOR=#0f172a
PWA_START_URL=/?source=pwa
PWA_SCOPE=/
PWA_PUSH_PUBLIC_KEY=
